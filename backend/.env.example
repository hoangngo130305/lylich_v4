# ============================================================
#  .env.example — copy to .env and fill in real values
# ============================================================

# ── Django Core ─────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=your-very-long-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost

# ── Database (MariaDB 10.11) ─────────────────────────────────
DB_ENGINE=django.db.backends.mysql
DB_NAME=lylich_dang
DB_USER=lylich_user
DB_PASSWORD=your_strong_db_password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_SIGNING_KEY=your-jwt-signing-key-different-from-secret-key

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# ── Email ────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=Ban XD Đảng <noreply@yourdomain.com>

# ── File Storage ─────────────────────────────────────────────
MEDIA_ROOT=/app/media
MEDIA_URL=/media/
STATIC_ROOT=/app/staticfiles
MAX_UPLOAD_SIZE_MB=10

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── External APIs ────────────────────────────────────────────
ZALO_OA_TOKEN=your_zalo_oa_access_token
ZALO_OA_ID=your_zalo_oa_id
SMS_API_KEY=your_sms_provider_api_key
SMS_API_URL=https://sms-provider.com/api/send

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/var/log/lylich/django.log

# ── Frontend URL (for CORS and email links) ──────────────────
FRONTEND_URL=http://localhost:8080
