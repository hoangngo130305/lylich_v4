    "profile.temporary_address": "Nơi tạm trú",
    "profile.ethnic_group.name": "Dân tộc",
    "profile.religion.name": "Tôn giáo",
    "profile.occupation": "Nghề nghiệp hiện nay",
    "profile.general_edu_level": "Giáo dục phổ thông",
    "profile.edu_level.name": "Chuyên môn nghiệp vụ",
    "profile.science_tech_qualifications": "Khoa học công nghệ",
    "profile.highest_degree": "Học vị cao nhất",
    "profile.academic_title": "Học hàm cao nhất",
    "profile.political_level.name": "Lý luận chính trị",
    "profile.foreign_languages": "Ngoại ngữ",
    "profile.it_level": "Tin học",
    "profile.ethnic_language": "Tiếng dân tộc thiểu số",
    "profile.youth_union_date": "Ngày vào Đoàn TNCS HCM",
    "profile.youth_union_place": "Nơi vào Đoàn",
    "profile.rejoin_introducer1_name": "Người giới thiệu vào Đảng (1)",
