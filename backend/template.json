        },
        {
          "field_no": "02",
          "label": "Họ và tên thường dùng",
          "field": "profile.full_name_other"
        },
        {
          "field_no": "03",
          "label": "Ngày sinh",
          "field": "profile.dob",
          "format": "DD/MM/YYYY"
        },
        {
          "field_no": "04",
          "label": "Giới tính",
          "field": "profile.get_gender_display"
        },
        {
          "field_no": "05",
          "label": "Nơi đăng ký khai sinh",
          "field": "profile.birth_place_detail"
        },
        {
          "field_no": "06",
          "label": "Quê quán",
          "field": "profile.hometown_detail"
        },
        {
          "field_no": "07a",
          "label": "Nơi thường trú",
          "field": "profile.current_address"
        },
        {
          "field_no": "07b",
          "label": "Nơi tạm trú",
          "field": "profile.temporary_address"
        },
        {
          "field_no": "08",
          "label": "Dân tộc",
          "field": "profile.ethnic_group.name",
          "fallback": "profile.ethnic_group_other"
        },
        {
          "field_no": "09",
          "label": "Tôn giáo",
          "field": "profile.religion.name",
          "fallback": "profile.religion_other"
        },
        {
          "field_no": "09b",
          "label": "Chức sắc tôn giáo",
          "field": "profile.religious_title"
        },
        {
          "field_no": "10",
          "label": "Nghề nghiệp hiện nay",
          "field": "profile.occupation"
        }
      ]
    },
    {
      "id": "phan_a_edu",
      "type": "table_static",
